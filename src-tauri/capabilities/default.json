{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Sentinel windows",
  "windows": ["main", "mini-overlay"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:window:allow-close",
    "core:window:allow-set-position",
    "core:window:allow-set-size"
  ]
}
